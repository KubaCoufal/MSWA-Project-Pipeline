# Backend API URL used by browser requests.
VITE_API_BASE_URL=http://localhost:8000

# Authentication mode: "demo" for built-in demo users, or "keycloak" for SSO.
VITE_AUTH_MODE=demo

# Keycloak settings are only used when VITE_AUTH_MODE=keycloak.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=pipeline-monitor
VITE_KEYCLOAK_CLIENT_ID=pipeline-monitor-web
